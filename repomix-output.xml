    li {
      flex: 1 1 calc(50% - 8px);
    }

    a {
      width: 100%;
      justify-content: center;
      box-sizing: border-box;
    }
  }

  @media (max-width: 768px) {
    margin-top: 16px;
    gap: 6px;

    li {
      flex: 1 1 calc(50% - 6px);
    }

    a {
      font-size: 14px;
      padding: 5px 10px;
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    margin-top: 12px;
    gap: 4px;
    flex-wrap: wrap;

    li {
      flex: 1 1 100%;
    }

    a {
      font-size: 12px;
      padding: 4px 8px;
      width: 100%;
    }
  }
}

#spacer {
  height: 88px;
  border-top: 1px solid var(--border);
  @media (max-width: 1024px) {
    height: 48px;
  }

  @media (max-width: 768px) {
    height: 32px;
  }

  @media (max-width: 480px) {
    height: 24px;
  }
}

.ticks {
  position: relative;
  width: 100%;

  &::before,
  &::after {
    content: '';
    position: absolute;
    top: -4.5px;
    border: 5px solid transparent;
  }

  &::before {
    left: 0;
    border-left-color: var(--border);
  }
  &::after {
    right: 0;
    border-right-color: var(--border);
  }
}

